# ── TT Learning Library — environment (example) ──────────────────────────────
# Copy to `.env` and adjust. `.env` and `.env.local` are gitignored.
#
# Database: PostgreSQL only. The app ships a docker-compose Postgres instance:
#   bun run db:up     # starts container tt-learning-db on host port 5433
DATABASE_URL="postgres://ttlearn:ttlearn_local@localhost:5433/tt_learning?sslmode=disable"
#
# Tests reset a `tt_test` schema inside this database (no extra DB needed):
# TEST_SCHEMA="tt_test"
# TEST_DATABASE_URL="postgres://ttlearn:ttlearn_local@localhost:5433/tt_learning?sslmode=disable"
#
# ── API ───────────────────────────────────────────────────────────────────────
PORT=3003
WEB_ORIGIN="http://localhost:5174"
HOSTED_AUTH_REQUIRED=false
#
# ── Standalone feedback service (UI ─► /api/feedback ─► proxy) ───────────────
FEEDBACK_SERVICE_URL="https://feedback.graceliu.uk"
FEEDBACK_APP_ID="tt-learning-library"
#
# ── Production (Supabase PostgreSQL) ─────────────────────────────────────────
# Use the session pooler for the persistent Render API and the provider CA for
# certificate verification. Keep the password and CA in the deployment host.
# DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=verify-full"
# DATABASE_CA_CERT="-----BEGIN CERTIFICATE-----\\n...\\n-----END CERTIFICATE-----"

# ── Hosted authentication (Supabase) ─────────────────────────────────────────
# SUPABASE_URL="https://<project-ref>.supabase.co"
# SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
# VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."
# AUTH_COOKIE_SECRET="generate-at-least-32-random-characters"
# HOSTED_AUTH_REQUIRED="true"
# LEGACY_OWNER_EMAIL="owner@example.com"
# NODE_TLS_REJECT_UNAUTHORIZED=0
