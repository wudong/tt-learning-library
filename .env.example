# ── TT Learning Library — environment (example) ──────────────────────────────
# Copy to `.env` and adjust. `.env` and `.env.local` are gitignored.
#
# Database: PostgreSQL only. The app ships a docker-compose Postgres instance:
#   bun run db:up     # starts container tt-learning-db on host port 5433
DATABASE_URL="postgres://ttlearn:ttlearn_local@localhost:5433/tt_learning?sslmode=disable"
#
# Tests reset a `tt_test` schema inside this database (no extra DB needed):
# TEST_SCHEMA="tt_test"
# TEST_DATABASE_URL="postgres://ttlearn:ttlearn_local@localhost:5433/tt_learning?sslmode=disable"
#
# ── API ───────────────────────────────────────────────────────────────────────
PORT=3003
WEB_ORIGIN="http://localhost:5174"
HOSTED_AUTH_REQUIRED=false
#
# ── Standalone feedback service (UI ─► /api/feedback ─► proxy) ───────────────
FEEDBACK_SERVICE_URL="https://feedback.graceliu.uk"
FEEDBACK_APP_ID="tt-learning-library"
#
# ── Production (Aiven PostgreSQL) ────────────────────────────────────────────
# Only set on the host (Render). Requires NODE_TLS_REJECT_UNAUTHORIZED=0 because
# Aiven uses a self-signed CA in the chain on the free plan.
# DATABASE_URL="postgres://ttlearn:<password>@tt-learning-db-tt-learn.h.aivencloud.com:10990/tt_learning?sslmode=require"
# NODE_TLS_REJECT_UNAUTHORIZED=0